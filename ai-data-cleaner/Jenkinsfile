pipeline {
    agent any
    
    environment {
        DOCKER_REGISTRY = 'docker.io'
        IMAGE_NAME = 'ai-data-cleaner'
        DOCKER_HUB_REPO = 'pushpak26/ai-data-cleaner'
        DOCKER_HUB_CREDENTIALS = credentials('dockerhub-credentials')
        GITOPS_REPO = 'https://github.com/Pushpakp26/ai-data-cleaner-gitops.git'
        GITOPS_CREDENTIALS = credentials('github-credentials')
        KUBECONFIG = credentials('kubeconfig')
    }
    
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        
        stage('Test') {
            steps {
                sh '''
                    python -m pytest tests/ --junitxml=test-results.xml
                    python -m flake8 server/ --output-file=flake8-report.txt || true
                '''
            }
            post {
                always {
                    junit 'test-results.xml'
                    publishHTML([
                        allowMissing: false,
                        alwaysLinkToLastBuild: true,
                        keepAll: true,
                        reportDir: '.',
                        reportFiles: 'flake8-report.txt',
                        reportName: 'Flake8 Report'
                    ])
                }
            }
        }
        
        stage('Build Docker Image') {
            steps {
                script {
                    def imageTag = "${BUILD_NUMBER}-${GIT_COMMIT.take(7)}"
                    env.IMAGE_TAG = imageTag
                    
                    def image = docker.build("${DOCKER_HUB_REPO}:${imageTag}")
                    
                    // Push to Docker Hub
                    docker.withRegistry("https://${DOCKER_REGISTRY}", 'dockerhub-credentials') {
                        image.push()
                        image.push('latest')
                    }
                    
                    // Store image tag for GitOps update
                    writeFile file: 'image-tag.txt', text: imageTag
                    archiveArtifacts artifacts: 'image-tag.txt'
                }
            }
        }
        
        stage('Update GitOps Repo') {
            steps {
                script {
                    def imageTag = readFile('image-tag.txt').trim()
                    
                    withCredentials([usernamePassword(credentialsId: 'github-credentials', usernameVariable: 'GIT_USERNAME', passwordVariable: 'GIT_PASSWORD')]) {
                        sh '''
                            git clone https://${GIT_USERNAME}:${GIT_PASSWORD}@github.com/Pushpakp26/ai-data-cleaner-gitops.git gitops-repo
                            cd gitops-repo
                            
                            # Update image tag in deployment.yaml
                            sed -i "s|image: .*/ai-data-cleaner:.*|image: ${DOCKER_HUB_REPO}:${IMAGE_TAG}|" k8s/deployment.yaml
                            
                            git config user.email "jenkins@company.com"
                            git config user.name "Jenkins CI"
                            git add k8s/deployment.yaml
                            git commit -m "Update image tag to ${IMAGE_TAG} [skip ci]"
                            git push origin main
                        '''
                    }
                }
            }
        }
        
        stage('Security Scan') {
            steps {
                sh '''
                    # Trivy security scan
                    trivy image ${DOCKER_HUB_REPO}:${IMAGE_TAG} --format json --output trivy-report.json || true
                    
                    # SAST scan with SonarQube (optional)
                    # sonar-scanner \
                    #   -Dsonar.projectKey=ai-data-cleaner \
                    #   -Dsonar.sources=server/ \
                    #   -Dsonar.host.url=${SONAR_HOST_URL} \
                    #   -Dsonar.login=${SONAR_TOKEN}
                '''
            }
            post {
                always {
                    archiveArtifacts artifacts: 'trivy-report.json', allowEmptyArchive: true
                }
            }
        }
    }
    
    post {
        always {
            cleanWs()
        }
        success {
            echo "✅ AI Data Cleaner build ${BUILD_NUMBER} succeeded!"
            echo "🐳 Docker image: ${DOCKER_HUB_REPO}:${IMAGE_TAG}"
            // Optional: Slack notification
            // slackSend(
            //     channel: '#deployments',
            //     color: 'good',
            //     message: "✅ AI Data Cleaner build ${BUILD_NUMBER} succeeded!"
            // )
        }
        failure {
            echo "❌ AI Data Cleaner build ${BUILD_NUMBER} failed!"
            // Optional: Slack notification
            // slackSend(
            //     channel: '#deployments',
            //     color: 'danger',
            //     message: "❌ AI Data Cleaner build ${BUILD_NUMBER} failed!"
            // )
        }
    }
}
pipeline {
    agent {
        kubernetes {
            yaml '''
apiVersion: v1
kind: Pod
spec:
  containers:
  - name: python
    image: python:3.9-slim
    command: ["cat"]
    tty: true
  - name: docker
    image: docker:latest
    command: ["cat"]
    tty: true
    volumeMounts:
    - name: docker-sock
      mountPath: /var/run/docker.sock
  volumes:
  - name: docker-sock
    hostPath:
      path: /var/run/docker.sock
'''
        }
    }
    
    environment {
        DOCKER_REGISTRY = 'docker.io'
        DOCKER_HUB_REPO = 'pushpak26/ai-data-cleaner'
        IMAGE_TAG = "${BUILD_NUMBER}-${GIT_COMMIT.take(7)}"
        DOCKER_HUB_CREDENTIALS = credentials('dockerhub-credentials')
        GITOPS_REPO = 'https://github.com/Pushpakp26/ai-data-cleaner-gitops.git'
    }
    
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Test') {
            steps {
                container('python') {
                    sh '''
                        pip install pytest flake8
                        # Check if tests exist, if not skip
                        if [ -d "ai-data-cleaner/tests" ]; then
                            python -m pytest ai-data-cleaner/tests/ -v --junitxml=test-results.xml -p no:cacheprovider || true
                        else
                            echo "No tests directory found, skipping tests"
                            echo '<?xml version="1.0" encoding="utf-8"?><testsuites><testsuite name="pytest" tests="0" failures="0" errors="0" time="0.0"></testsuite></testsuites>' > test-results.xml
                        fi
                        
                        # Run flake8 on server directory
                        if [ -d "ai-data-cleaner/server" ]; then
                            python -m flake8 ai-data-cleaner/server/ --output-file=flake8-report.txt || true
                        else
                            echo "No server directory found" > flake8-report.txt
                        fi
                    '''
                }
            }
            post {
                always {
                    junit allowEmptyResults: true, testResults: 'test-results.xml'
                }
            }
        }
        
        stage('Build Docker Image') {
            steps {
                container('docker') {
                    script {
                        // Build from the correct directory
                        sh """
                            cd ai-data-cleaner
                            docker build -f Dockerfile -t ${DOCKER_HUB_REPO}:${IMAGE_TAG} ..
                        """

                        withCredentials([usernamePassword(credentialsId: 'dockerhub-credentials', usernameVariable: 'USER', passwordVariable: 'PASS')]) {
                            sh "echo ${PASS} | docker login -u ${USER} --password-stdin"
                            sh "docker push ${DOCKER_HUB_REPO}:${IMAGE_TAG}"
                        }

                        writeFile file: 'image-tag.txt', text: IMAGE_TAG
                    }
                }
            }
        }
        
        stage('Update GitOps Repo') {
            steps {
                container('python') {
                    script {
                        withCredentials([usernamePassword(credentialsId: 'github-credentials', usernameVariable: 'GIT_USERNAME', passwordVariable: 'GIT_PASSWORD')]) {
                            sh """
                                git clone https://${GIT_USERNAME}:${GIT_PASSWORD}@github.com/Pushpakp26/ai-data-cleaner-gitops.git gitops-repo
                                cd gitops-repo
                                
                                # Update image tag in deployment.yaml
                                sed -i "s|image: .*/ai-data-cleaner:.*|image: ${DOCKER_HUB_REPO}:${IMAGE_TAG}|" k8s/deployment.yaml
                                
                                git config user.email "jenkins@company.com"
                                git config user.name "Jenkins CI"
                                git add k8s/deployment.yaml
                                git commit -m "Update image tag to ${IMAGE_TAG} [skip ci]"
                                git push origin main
                            """
                        }
                    }
                }
            }
        }
    }
    
    post {
        always {
            deleteDir()
        }
        success {
            echo "✅ AI Data Cleaner build ${BUILD_NUMBER} succeeded!"
            echo "🐳 Docker image: ${DOCKER_HUB_REPO}:${IMAGE_TAG}"
        }
        failure {
            echo "❌ AI Data Cleaner build ${BUILD_NUMBER} failed!"
        }
    }
}
